{
  "id": null,
  "title": "DevSecOps Security Dashboard",
  "tags": ["security", "devsecops"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1, "title": "🚨 Total Attack Attempts", "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(security_attack_attempts_total) or vector(0)", "legendFormat": "Attacks"}],
      "options": {"colorMode": "background", "graphMode": "area"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "id": 2, "title": "🔒 Blocked IPs", "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "security_blocked_ips_total or vector(0)", "legendFormat": "Blocked"}],
      "options": {"colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}}
    },
    {
      "id": 3, "title": "📊 Total Requests", "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(app_request_count_total) or vector(0)", "legendFormat": "Requests"}],
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 4, "title": "⚡ Failed Login Attempts", "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(security_failed_logins_total) or vector(0)", "legendFormat": "Failed Logins"}],
      "options": {"colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 3}, {"color": "red", "value": 10}]}}}
    },
    {
      "id": 5, "title": "🔴 Attack Attempts Over Time", "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [
        {"expr": "rate(security_attack_attempts_total[1m])", "legendFormat": "{{attack_type}}"},
        {"expr": "rate(security_suspicious_requests_total[1m])", "legendFormat": "Suspicious: {{reason}}"}
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}}
    },
    {
      "id": 6, "title": "📈 Request Rate by Endpoint", "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [{"expr": "rate(app_request_count_total[1m])", "legendFormat": "{{method}} {{endpoint}} ({{status}})"}]
    },
    {
      "id": 7, "title": "⏱️ Avg Response Latency", "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 13},
      "targets": [{"expr": "rate(app_request_latency_seconds_sum[5m]) / rate(app_request_latency_seconds_count[5m])", "legendFormat": "{{endpoint}}"}]
    },
    {
      "id": 8, "title": "🔗 Active Connections", "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 13},
      "targets": [{"expr": "app_active_connections", "legendFormat": "Active Connections"}]
    }
  ]
}
